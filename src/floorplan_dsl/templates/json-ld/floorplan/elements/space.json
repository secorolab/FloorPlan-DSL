        {
            "@id": "{{ space.name }}",
            "@type": "Space",
            "walls": [
            {% for w in space.walls %}
                "{{ w.name }}"{%- if not loop.last %},
            {% endif %}
            {% endfor +%}
            ],
            "feature": [
            {% for feature in space.features %}
                "{{ feature.name }}"{%- if not loop.last %},
            {% endif %}
            {% endfor +%}
            ],
            "shape": "{{ space.shape.name }}"
        }
