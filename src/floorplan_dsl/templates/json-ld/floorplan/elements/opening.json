{
  "@id": "{{ element.name }}",
  "@type": "{{ element.__class__.__name__ }}",
  "shape": "{{ element.shape.name }}",
  "3d-shape": "{{ element.shape_3d.name }}",
  "thickness": {{ element.shape_3d.thickness.value }},
  "voids": [
    {% for container in element.wall_ids %}
      "{{ container }}"{%- if not loop.last %},
            {% endif %}
    {% endfor +%}
  ]
}
